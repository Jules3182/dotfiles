{
  "name": "bottom-bar",
  "layer": "top",
  "output": "DP-3",
  "position": "bottom",

  "modules-left": ["tray"],

  "modules-center": ["hyprland/workspaces"],
  
  "hyprland/workspaces":{
    "format": "{name}",
    "persistent-workspaces": {
      "DP-3": [ 1, 2, 3, 4, 5 ]
    }
  },
  "tray": {
	  "icon-size": 21,
	  "spacing": 10//,
//    "actions": {
//      "on-scroll-down": "shift_up",
//      "on-scroll-up": "shift_down"
//    }
  }
}
